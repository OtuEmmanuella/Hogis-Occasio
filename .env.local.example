# Supabase (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email — Resend (free tier: 100 emails/day) https://resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=notifications@yourdomain.com

# SMS — Twilio (free trial) https://www.twilio.com
# OR use Africa's Talking (great for Nigeria/Africa) https://africastalking.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your_twilio_number

# Africa's Talking (alternative to Twilio, better for Africa)
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=your_africastalking_username
AFRICASTALKING_SENDER_ID=HOGIS

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Hogis Occasio
